---
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  }

const { title = 'Skywalkr_2091 — Portfolio', description = 'Cyber Security SOC Analyst • AI Automation • Full‑stack' } = Astro.props as Props;
import "../styles/global.css";
import MobileDock from "../components/MobileDock.astro";
import GlyphGrid from "../components/GlyphGrid.astro";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07f0ff" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    
  </head>
  <body class="page-transition">
    <style is:global>
      #preloader { position: fixed; inset: 0; display: grid; place-items: center; z-index: 120; background: #000; backdrop-filter: none; opacity: 1; transition: opacity .45s ease; cursor: pointer; }
      #preloader.hide { opacity: 0; pointer-events: none }
      #preloader .intro-inner { text-align: center; padding: 20px }
      #preloader .intro-text { font-weight: 900; letter-spacing: 2px; font-size: clamp(28px, 8vw, 56px); color: #07f0ff; background: linear-gradient(90deg, #07f0ff, #a24cff, #07f0ff); background-size: 200% 100%; -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; text-shadow: none; filter: none; margin-top: 10px; animation: gradShift 3s ease-in-out infinite; }
      #preloader .d { color: rgba(7, 240, 255, 0.8); opacity: 1 }
      .intro-typing { display: inline-flex; align-items: center; gap: 2px; }
      .pre-cursor { display:inline-block; width:8px; height:1.2em; background:#07f0ff; border-radius:1px; box-shadow:0 0 8px #07f0ff; margin-left:4px; opacity:.9; animation: blink-cursor 1s steps(2) infinite; }
      @keyframes blink-cursor { 0%,100% { opacity: 0 } 50% { opacity: 1 } }
      .spinner { width: 72px; height: 72px; border-radius: 50%; border: 2px solid color-mix(in oklab, var(--neon-cyan) 25%, transparent); position: relative; margin: 0 auto 16px; box-shadow: 0 0 20px rgba(7,240,255,.15) inset; }
      .spinner::before, .spinner::after { content: ""; position: absolute; inset: -2px; border-radius: 50%; border: 2px solid transparent; }
      .spinner::before { border-top-color: var(--neon-cyan); border-left-color: color-mix(in oklab, var(--neon-cyan) 60%, transparent); filter: drop-shadow(0 0 10px var(--neon-cyan)); animation: spin360 1s linear infinite; }
      .spinner::after { border-right-color: var(--neon-purple); border-bottom-color: color-mix(in oklab, var(--neon-purple) 60%, transparent); filter: drop-shadow(0 0 8px var(--neon-purple)); animation: spin360 1.8s linear infinite reverse; }
      @keyframes spin360 { to { transform: rotate(360deg) } }
      @keyframes gradShift { 0%,100% { background-position: 0% 0 } 50% { background-position: 100% 0 } }
      .skip { margin-top: 12px; background: transparent; color: #9fb8ff; border: 1px solid rgba(255,255,255,.2); padding: 6px 10px; border-radius: 8px; cursor: pointer; }
      .skip:hover { border-color: rgba(255,255,255,.4); color: #cfe0ff; }
    </style>
    <div id="preloader" aria-live="polite" aria-busy="true">
      <div class="intro-inner">
        <div class="spinner" aria-hidden="true"></div>
        <div class="intro-typing" aria-label="Loading">
          <span id="pre-text" class="intro-text">Sayanth <span class="d">Sreekanth</span></span><span class="pre-cursor" aria-hidden="true"></span>
        </div>
      </div>
    </div>
    <GlyphGrid />
    <div id="scroll-progress" aria-hidden="true"></div>
    <main>
      <slot />
    </main>
    <MobileDock />
    <script src="/scripts/glyph-grid.js" defer></script>
    <script src="/scripts/app-init.js" defer></script>
    <script src="/scripts/holo-init.js" defer></script>
    <script src="/scripts/starfield-init.js" defer></script>
    <script src="/scripts/code-typing.js" defer></script>
    <!-- command palette removed -->
    <script src="/scripts/cursor-trail.js" defer></script>
    <script src="/scripts/scroll-animations.js" defer></script>
    <script src="/scripts/intro-morph.js" defer></script>
  </body>
</html>






