---
import Cursor from '../components/Cursor.astro';
import GrainOverlay from '../components/GrainOverlay.astro';
import SideNav from '../components/SideNav.astro';
import ScrollHint from '../components/ScrollHint.astro';
import AudioController from '../components/AudioController.astro';
import BootSequence from '../components/BootSequence.astro';
import Terminal from '../components/Terminal.tsx';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'NULL_SECTOR — Sayanth Sreekanth',
  description = 'SOC analyst. Threat hunter. Detection engineer.',
  ogImage = `${import.meta.env.BASE_URL}og.png`,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- open graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />

    <!-- structured data: Person schema -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Sayanth Sreekanth',
      alternateName: 'skywalkr_2091',
      jobTitle: 'SOC Analyst, Security Researcher',
      url: canonicalURL.toString(),
      sameAs: [
        'https://github.com/Sayanth2091',
        'https://www.linkedin.com/in/sayanth-sreekanth-289950188',
      ],
    })} />

    <!-- fonts: Google Fonts CDN (self-hosted in step 10) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Inter+Tight:wght@300;500&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="bg-void text-fg-high min-h-screen">
    <BootSequence />
    <GrainOverlay />
    <Cursor />
    <SideNav />
    <ScrollHint />
    <AudioController />
    <Terminal client:idle />

    <main>
      <slot />
    </main>
  </body>

  <script>
    import '../scripts/konami';
    import '../scripts/tab-title';
  </script>
</html>
