---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a,b)=> b.data.date.getTime()-a.data.date.getTime());
---
<Base title="All Posts — Skywalkr_2091" description="All blog posts by Sayanth.">
  <Nav />
  <main class="section" data-reveal>
    <div class="container">
      <h1>All Posts</h1>
      <div class="cards">
        {posts.map(({ data, slug }) => (
          <a class="card blog-card" href={`/blog/${slug}/`} style={`view-transition-name: blog-${slug}`}>
            <div class="cover-thumb" style={`view-transition-name: cover-blog-${slug}`}></div>
            <h3>{data.title}</h3>
            <p class="muted">{data.description ?? ''}</p>
            <p class="muted date">{new Date(data.date).toDateString()}</p>
          </a>
        ))}
      </div>
    </div>
    <Footer />
  </main>
</Base>

<style>
  .blog-card { text-decoration: none; display: flex; flex-direction: column; }
  .date { margin-top: auto; padding-top: 12px; }
  .cover-thumb { height: 120px; border-radius: 10px; border:1px solid var(--grid); margin-bottom: 12px; background: radial-gradient(180px 90px at 20% 30%, color-mix(in oklab, var(--neon-cyan) 25%, transparent), transparent), radial-gradient(160px 80px at 80% 70%, color-mix(in oklab, var(--neon-purple) 25%, transparent), transparent), #08121f; }
</style>

