---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
---
<Base title="Blog — Skywalkr_2091" description="Notes on security, automation and dev by Sayanth.">
  <Nav />
  <main class="section" data-reveal>
    <div class="container">
      <h1>Blog</h1>
      <div class="cards">
        <a class="card" href="/blog/self-learning" style="view-transition-name: blog-cat-self-learning">
          <h3>Technical Deep Dives & Build Logs</h3>
          <p class="muted">In-depth articles and logs from my ongoing exploration of technology.</p>
        </a>
        <a class="card" href="/blog/tools" style="view-transition-name: blog-cat-tools">
          <h3>Guides & Resources</h3>
          <p class="muted">Practical guides, tutorials, and recommendations for tools and technologies.</p>
        </a>
      </div>
    </div>
    <Footer />
  </main>
</Base>
