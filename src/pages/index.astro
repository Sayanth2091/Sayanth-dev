---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import HoloShape from "../components/HoloShape.astro";
 
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import SkillsGrid from "../components/SkillsGrid.astro";

// Optimized assets (moved from /public/images to /src/assets for astro:assets)
import aiChat from "../assets/AI/AI Chat.png";
import ai1 from "../assets/AI/Ai 1.png";
import ai2 from "../assets/AI/Ai 2.png";
import usm from "../assets/Cybersecurity/USM.jpg";
import ossim from "../assets/Cybersecurity/Ossim.png";
import elk from "../assets/Cybersecurity/Elk.png";

const projects = (await getCollection('projects')).sort((a,b)=> b.data.date.getTime()-a.data.date.getTime());
const featured = projects.filter(p=>p.data.featured).slice(0,3);
---
<Base>
  <Nav />
  <main>
    <Hero />

    <section class="section" data-reveal>
      <div class="container">
        <h2>About</h2>
        <div class="prose-wrap">
          <div class="prose">
            <p data-reveal="left">
              I’m a final‑year Integrated M.Tech student in Cybersecurity at VIT Bhopal and a SOC Analyst (L1) at Digital Insights (Dubai).
              Day to day, I monitor threats, investigate alerts, and turn noisy signals into clear action.
            </p>
            <p data-reveal="right">
              I care about pragmatic security: build reliable detections, respond fast, and automate the repetitive bits.
              Lately, I’ve been using n8n and lightweight AI to speed up triage and reduce toil.
            </p>
            <div class="highlights" data-reveal="left">
              <span class="badge">SOC Monitoring</span>
              <span class="badge">Incident Response</span>
              <span class="badge">MITRE ATT&CK</span>
              <span class="badge">AlienVault USM</span>
              <span class="badge">SIEM Analysis</span>
              <span class="badge">EDR</span>
              <span class="badge">AI + n8n</span>
            </div>
          </div>
        </div>
        <a href="/about" class="btn">More About Me</a>
      </div>
    </section>

    

    

    <section class="section" id="projects" data-reveal>
      <div class="container">
        <h2>Featured Projects</h2>
        <div class="cards">
          {featured.map(({ data, slug }) => (
            <a class="card" href={`/projects/${slug}/`} style={`view-transition-name: project-${slug}`}>
              <div class="cover-thumb" style={`view-transition-name: cover-project-${slug}`}></div>
              <h3>{data.title}</h3>
              <p class="muted">{data.summary}</p>
              <p>{data.stack.map(s => (<span class="badge">{s}</span>))}</p>
            </a>
          ))}
        </div>
        <div style="margin-top:14px">
          <a href="/projects" class="btn">View all projects</a>
        </div>
      </div>
    </section>

    <section class="section" id="ai" data-reveal>
      <div class="container split">
        <div>
          <h2>AI Automation</h2>
          <p class="muted">I use small, composable AI tools to cut busywork—paired with n8n, Python and simple guardrails so results are reliable and auditable.</p>
          <p>
            <span class="badge">Agents</span>
            <span class="badge">RAG</span>
            <span class="badge">Prompting</span>
            <span class="badge">Eval & Guardrails</span>
          </p>
          <div class="img-row tilt-row" data-tilt>
            <Image src={ai1} alt="AI workflow visualization" widths={[220, 440]} sizes="(max-width: 900px) 100vw, 220px" formats={["avif","webp","png"]} placeholder="blur" />
            <Image src={ai2} alt="AI dashboard snapshot" widths={[220, 440]} sizes="(max-width: 900px) 100vw, 220px" formats={["avif","webp","png"]} placeholder="blur" />
          </div>
        </div>
        <HoloShape type="ico" color="#07f0ff" size={220} />
      </div>
    </section>

    

    <section class="section" id="security" data-reveal>
      <div class="container split">
        <div>
          <h2>Cybersecurity</h2>
          <p class="muted">SOC analysis, detection engineering and threat hunting. I focus on clear playbooks and visual tools that make triage faster without losing traceability.</p>
          <p>
            <span class="badge">SIEM</span>
            <span class="badge">Detection Eng</span>
            <span class="badge">Threat Hunting</span>
            <span class="badge">Forensics</span>
          </p>
          <div class="img-row tilt-row" data-tilt>
            <Image src={usm} alt="AlienVault USM SIEM dashboard" widths={[220, 440]} sizes="(max-width: 900px) 100vw, 220px" formats={["avif","webp","jpeg"]} placeholder="blur" />
            <Image src={ossim} alt="OSSIM interface" widths={[220, 440]} sizes="(max-width: 900px) 100vw, 220px" formats={["avif","webp","png"]} placeholder="blur" />
            <Image src={elk} alt="ELK stack dashboard" widths={[220, 440]} sizes="(max-width: 900px) 100vw, 220px" formats={["avif","webp","png"]} placeholder="blur" />
          </div>
        </div>
        <HoloShape type="knot" color="#a24cff" size={220} />
      </div>
    </section>

    <section class="section" id="automations" data-reveal>
      <div class="container split">
        <div>
          <h2>n8n Automations</h2>
          <p class="muted">From alert intake to ticketing: modular n8n workflows with human-in-the-loop steps, webhook triggers and Slack/Teams integrations.</p>
          <p>
            <span class="badge">n8n</span>
            <span class="badge">Webhooks</span>
            <span class="badge">Approvals</span>
            <span class="badge">Ticketing</span>
          </p>
          <div class="img-row">
            <Image src={aiChat} alt="AI chat interface mock" widths={[220, 440]} sizes="(max-width: 900px) 100vw, 220px" formats={["avif","webp","png"]} placeholder="blur" />
            </div>
        </div>
        <HoloShape type="ico" color="#5fe7ff" size={220} />
      </div>
    </section>

    <SkillsGrid />

    

    

    <Footer />
  </main>
</Base>

<style>
  .card { text-decoration: none; }
  .orbit{ position:relative; height:220px; display:grid; place-items:center }
  .orbit .core{ width:14px; height:14px; border-radius:999px; background: var(--neon-cyan); box-shadow: 0 0 18px color-mix(in oklab, var(--neon-cyan) 60%, transparent) }
  .ring{ position:absolute; width: 60%; height: 60%; border-radius: 50%; border:1px dashed color-mix(in oklab, var(--neon-cyan) 40%, transparent); animation: spin 12s linear infinite }
  .ring span{ position:absolute; width:10px; height:10px; border-radius:999px; background: var(--neon-purple); top:-5px; left:50%; transform: translateX(-50%); box-shadow: 0 0 12px color-mix(in oklab, var(--neon-purple) 60%, transparent) }
  .ring.r2{ width: 80%; height: 80%; animation-duration: 18s; animation-direction: reverse; border-color: color-mix(in oklab, var(--neon-purple) 40%, transparent) }
  .ring.r2 span{ background: var(--neon-cyan) }
  .ring.r3{ width: 40%; height: 40%; animation-duration: 9s }
  @keyframes spin{ to{ transform: rotate(360deg) } }
  
  /* Removed legacy stack-cards styles */

  /* Tilt row parallax */
  .tilt-row { perspective: 800px; transform-style: preserve-3d; will-change: transform; }
  .tilt-row { transform: rotateX(var(--tilt-rx, 0deg)) rotateY(var(--tilt-ry, 0deg)); transition: transform .25s ease; }
  .tilt-row:hover { transition: transform .08s ease; }
  .tilt-row > *:nth-child(1) { transform: translateZ(20px); }
  .tilt-row > *:nth-child(2) { transform: translateZ(10px); }
  .tilt-row > *:nth-child(3) { transform: translateZ(0px); }
  /* Image sheen on hover */
  .img-row :global(picture) { position: relative; border-radius: 10px; overflow: hidden; }
  .img-row :global(picture)::after {
    content: ""; position: absolute; inset: -2px; pointer-events: none;
    background: linear-gradient(100deg, transparent 0%, color-mix(in oklab, var(--neon-cyan) 30%, transparent) 35%, color-mix(in oklab, var(--neon-purple) 30%, transparent) 50%, transparent 65%);
    transform: translateX(-120%);
    opacity: 0;
  }
  .img-row :global(picture):hover::after { animation: img-sheen 1.2s cubic-bezier(.22,.61,.36,1) both }
  @keyframes img-sheen { 0% { opacity: 0; transform: translateX(-120%) } 15% { opacity: .9 } 100% { opacity: 0; transform: translateX(120%) } }

  

  
</style>

