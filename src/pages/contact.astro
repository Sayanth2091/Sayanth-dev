---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Contact — Skywalkr_2091" description="Get in touch with Sayanth — security, AI automations, full‑stack.">
  <Nav />
  <main class="section" data-reveal>
    <div class="container" style="max-width: 820px;">
      <header>
        <h1 class="vt-title">Get In Touch</h1>
        <p class="muted">If you’d like to collaborate, hire me, or just compare notes on security and automation, I’d love to hear from you.</p>
      </header>

      <section class="cards">
        <a class="card" href="mailto:sayanthsreekanth5@gmail.com">
          <h3>Email</h3>
          <p class="muted">sayanthsreekanth5@gmail.com</p>
        </a>
        <a class="card" href="https://www.linkedin.com/in/sayanth-sreekanth-289950188/" target="_blank" rel="noopener noreferrer">
          <h3>LinkedIn</h3>
          <p class="muted">/in/sayanth-sreekanth-289950188</p>
        </a>
        <a class="card" href="https://github.com/Sayanth2091" target="_blank" rel="noopener noreferrer">
          <h3>GitHub</h3>
          <p class="muted">@Sayanth2091</p>
        </a>
        <a class="card" href="tel:+971585316698">
          <h3>Phone (UAE)</h3>
          <p class="muted">+971 58 531 6698</p>
        </a>
        <a class="card" href="tel:+916235733908">
          <h3>Phone (IN)</h3>
          <p class="muted">+91 623 573 3908</p>
        </a>
      </section>

      <section class="contact-note">
        <h2>What I can help with</h2>
        <ul>
          <li>Detection engineering, SOC analysis and threat hunting</li>
          <li>n8n automations (webhooks, approvals, ticketing)</li>
          <li>Lightweight AI agents, RAG, and operational tooling</li>
        </ul>
        <div class="availability">
          <strong>Availability</strong>
          <p class="muted">Open to internships, part‑time, and remote collaborations.</p>
        </div>
      </section>
    </div>
    <Footer />
  </main>
</Base>

<style>
  header { margin-bottom: 14px; }
  .cards { margin-top: 12px; }
  .card { text-decoration: none; }
  .contact-note { margin-top: 28px; }
  .contact-note ul { margin: 8px 0 0 18px; line-height: 1.7; }
  @media (max-width: 760px) {
    .cards { grid-template-columns: 1fr; }
  }
</style>
