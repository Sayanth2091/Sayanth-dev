---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from 'astro:content';
import type { MarkdownInstance } from 'astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

const { project } = Astro.props as { project: MarkdownInstance<Record<string, any>> };
const { Content } = await project.render();
---
<Base title={`${project.data.title} — Skywalkr_2091`} description={project.data.summary ?? ''}>
  <Nav />
  <main class="section">
    <div class="container" style="max-width: 820px;">
      <header data-reveal style={`view-transition-name: project-${project.slug}`}>
        <div class="cover-hero" style={`view-transition-name: cover-project-${project.slug}`}></div>
        <p class="muted">{new Date(project.data.date).toDateString()}</p>
        <h1 class="vt-title">{project.data.title}</h1>
        <p class="muted">{project.data.summary}</p>
        <p class="badges">{project.data.stack.map(s => (<span class="badge">{s}</span>))}</p>
      </header>
      <article class="prose">
        <Content />
      </article>
    </div>
    <Footer />
  </main>
</Base>



<style is:global>
  .badges { margin-top: 12px; }
  .cover-hero { height: 220px; border-radius: 14px; border:1px solid var(--grid); margin-bottom: 14px; background: radial-gradient(360px 180px at 20% 30%, color-mix(in oklab, var(--neon-cyan) 25%, transparent), transparent), radial-gradient(320px 160px at 80% 70%, color-mix(in oklab, var(--neon-purple) 25%, transparent), transparent), #08121f; box-shadow: 0 10px 28px rgba(7, 240, 255, 0.08) }
  .prose h2 { margin-top: 24px }
  .prose code { background: #0d1320; padding: 2px 6px; border-radius: 6px; }
  .prose pre { position: relative; background: #0d1320; padding: 16px; border-radius: 12px; overflow:auto; border:1px solid var(--grid)}
  .prose img { max-width:100%; height:auto; display:block; border-radius: 12px; border:1px solid var(--grid); margin: 16px auto; box-shadow: 0 10px 28px rgba(7, 240, 255, 0.08) }
  .prose blockquote { border-left: 3px solid var(--neon-cyan); padding-left: 1.5em; margin-left: 0; font-style: italic; color: var(--text-dim); }

  .prose pre .copy-btn {
    position: absolute;
    top: 12px;
    right: 12px;
    display: flex;
    align-items: center;
    gap: 6px;
    background: color-mix(in oklab, var(--bg) 50%, transparent);
    border: 1px solid var(--grid);
    color: var(--text-dim);
    padding: 6px 10px;
    border-radius: 8px;
    cursor: pointer;
    opacity: 0.7;
    transition: all .3s ease;
  }
  .prose pre:hover .copy-btn { opacity: 1; }
  .prose pre .copy-btn:hover { background: color-mix(in oklab, var(--neon-cyan) 15%, transparent); border-color: var(--neon-cyan); color: var(--text); }
  .prose pre .copy-btn[data-copied] { background: color-mix(in oklab, var(--neon-purple) 20%, transparent); border-color: var(--neon-purple); color: var(--text); }
  .prose pre .copy-btn svg { width: 16px; height: 16px; }
</style>


