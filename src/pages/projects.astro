---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a,b)=> b.data.date.getTime()-a.data.date.getTime());
---
<Base title="Projects — Skywalkr_2091" description="Selected projects by Sayanth Sreekanth">
  <Nav />
  <main class="section" data-reveal>
    <div class="container">
      <h1>Projects</h1>
      <div class="cards">
        {projects.map(({ data, slug }) => (
          <a class="card" href={`/projects/${slug}/`} style={`view-transition-name: project-${slug}`}>
            <div class="cover-thumb" style={`view-transition-name: cover-project-${slug}`}></div>
            <h3>{data.title}</h3>
            <p class="muted">{data.summary}</p>
            <p class="badges">{data.stack.map(s => (<span class="badge">{s}</span>))}</p>
            <div class="links">
              {data.link && <span class="btn">Live Demo</span>}
              {data.repo && <span class="btn secondary">Repo</span>}
            </div>
          </a>
        ))}
      </div>
    </div>
    <Footer />
  </main>
</Base>

<style>
  .card { text-decoration: none; }
  .badges { margin-bottom: 16px; }
  .links {
    margin-top: auto;
    padding-top: 16px;
    display: flex;
    gap: 10px;
    border-top: 1px solid var(--grid);
  }
  .card {
    display: flex;
    flex-direction: column;
  }
  .cover-thumb {
    height: 120px;
    border-radius: 10px;
    border: 1px solid var(--grid);
    margin-bottom: 12px;
    background: radial-gradient(180px 90px at 20% 30%, color-mix(in oklab, var(--neon-cyan) 25%, transparent), transparent), radial-gradient(160px 80px at 80% 70%, color-mix(in oklab, var(--neon-purple) 25%, transparent), transparent), #08121f;
  }
  .btn {
    display: inline-block;
    border: 1px solid var(--grid);
    padding: 8px 14px;
    border-radius: 8px;
    color: var(--text);
    text-decoration: none;
    background: color-mix(in oklab, var(--neon-cyan) 15%, transparent);
    transition: transform .3s ease, box-shadow .3s ease, background-color .3s ease;
  }
  .card:hover .btn {
    transform: translateY(-2px);
    box-shadow: 0 0 16px color-mix(in oklab, var(--neon-cyan) 30%, transparent);
  }
  .btn.secondary {
    background: transparent;
  }
  .card:hover .btn.secondary {
    border-color: var(--neon-purple);
    color: var(--neon-purple);
    box-shadow: 0 0 16px color-mix(in oklab, var(--neon-purple) 25%, transparent);
  }
</style>
