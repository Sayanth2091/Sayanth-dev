---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const posts = await getCollection('blog');
const stats = [
  { label: 'Projects', value: String(projects.length) },
  { label: 'Blog Posts', value: String(posts.length) },
  { label: 'Focus Areas', value: '4' },
  { label: 'Tech Stack', value: '8' },
];
---

<Base>
  <Nav />
  <main>
    <section class="section">
      <div class="container">
        <h1 data-reveal>About Me</h1>
        <h2 class="sub" data-reveal>Professional Overview</h2>
        <p data-reveal>
          I’m a detail‑oriented Cyber Security Analyst with hands‑on experience across SOC monitoring, incident response and penetration testing.
          At Digital Insights (Dubai), I investigate alerts using SIEM and EDR, document incidents with clear recommendations, and help deploy SIEM/VM boxes on client sites.
        </p>
        <p data-reveal>
          I like practical security: reduce noise, spot patterns, respond fast—then automate the boring parts with n8n and lightweight AI so humans stay focused on decisions.
        </p>
        <div class="highlights" data-reveal>
          <span class="badge">SOC Monitoring</span>
          <span class="badge">Incident Response</span>
          <span class="badge">MITRE ATT&CK</span>
          <span class="badge">AlienVault USM</span>
          <span class="badge">SIEM Analysis</span>
          <span class="badge">EDR</span>
          <span class="badge">AI + n8n</span>
        </div>
        
        <div class="quick-facts" data-reveal>
          <div class="fact"><strong>Current Role</strong><span>SOC Analyst (L1) — Digital Insights</span></div>
          <div class="fact"><strong>Location</strong><span>India • open to UAE/remote</span></div>
          <div class="fact"><strong>Focus</strong><span>IR, detections, automation</span></div>
        </div>
        <p data-reveal>
          If this resonates with your team, I’d love to connect on
          <a href="https://www.linkedin.com/in/sayanth-sreekanth-289950188/" target="_blank" rel="noopener">LinkedIn</a>
          or via <a href="mailto:sayanthsreekanth5@gmail.com">email</a>.
        </p>

        <h2 data-reveal>Experience</h2>
        <div class="cards">
          <div class="card">
            <h3>Digital Insights — SOC Analyst (L1)</h3>
            <p class="muted">Mar 2024 — Present • Dubai (Remote/Onsite)</p>
            <ul>
              <li>Investigate SIEM/EDR alerts; write IR docs with findings and recommendations</li>
              <li>Produce weekly threat reports and share processes in SOC meetups</li>
              <li>Assist onsite with SIEM and VM deployments</li>
            </ul>
          </div>
          <div class="card">
            <h3>Verzeo — Cyber Security Intern</h3>
            <p class="muted">Jan 2022 — Feb 2022 • Bengaluru</p>
            <ul>
              <li>Hands‑on with Metasploit, Nmap, Shodan; drafted pentest reports and presented findings</li>
            </ul>
          </div>
        </div>

        <h2 data-reveal>Education</h2>
        <div class="cards">
          <div class="card">
            <h3>VIT Bhopal — Integrated M.Tech (CSE, Cyber Security)</h3>
            <p class="muted">Sep 2020 — Jun 2025 • CGPA: 7.65</p>
          </div>
        </div>

        <h2 data-reveal>Certifications</h2>
        <ul>
          <li>Windows Forensics with Belkasoft — Mar 2025</li>
          <li>Digital Insights Internship — Jul 2024</li>
          <li>Verzeo Internship — Mar 2022</li>
        </ul>

        <h2 data-reveal>By the Numbers</h2>
        <div class="stats-grid" data-reveal>
          {stats.map((s) => (
            <div class="stat">
              <div class="stat-value">{s.value}</div>
              <div class="stat-label">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  

  .sub { margin-top: 8px; color: var(--text-dim); font-size: 18px; }
  .highlights { display:flex; flex-wrap: wrap; gap:8px; margin: 10px 0 18px; }
  .quick-facts {
    display:grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 10px;
    margin: 16px 0 10px;
  }
  .fact { border: 1px solid var(--grid); border-radius: 10px; padding: 12px 14px; background: color-mix(in oklab, var(--bg) 80%, transparent) }
  .fact strong { display:block; font-size: 12px; color: var(--text-dim); letter-spacing: .4px; }
  .fact span { display:block; margin-top: 4px; font-weight: 600; }

  .stats-grid { 
    display: grid; 
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); 
    gap: 12px; 
    margin-top: 12px; 
  }
  .stat { 
    text-align: center; 
    border: 1px solid var(--grid); 
    border-radius: 12px; 
    padding: 16px; 
    background: color-mix(in oklab, var(--bg) 80%, transparent); 
  }
  .stat-value { font-size: 28px; font-weight: 800; color: var(--neon-cyan); }
  .stat-label { color: var(--text-dim); font-size: 13px; margin-top: 4px; }
</style>
