---
// Operations.astro — Section 03: THE SECOND CUT
// Six case files. Vertical archive — each card reveals on scroll with a
// per-variant entrance. Three of the six diverge from the standard layout
// so the sequence rewards continued scrolling rather than repeating the
// same composition. Shard → State 2 on enter.
import { getCollection } from 'astro:content';
import CaseCard, { type CaseVariant } from './CaseCard.tsx';

const operations = await getCollection('operations');
const sorted = operations.sort((a, b) => a.data.order - b.data.order);

// Variant sequence cycles automatically so new operations beyond the
// initial six receive a layout without manual mapping.
// Pattern: standard · overprint · standard · strip · standard · oversize · repeat
const VARIANT_SEQUENCE: CaseVariant[] = [
  'standard',   // positions 1, 7, 13 …
  'overprint',  // positions 2, 8, 14 …
  'standard',   // positions 3, 9, 15 …
  'strip',      // positions 4, 10, 16 …
  'standard',   // positions 5, 11, 17 …
  'oversize',   // positions 6, 12, 18 …
];

const getVariant = (order: number): CaseVariant =>
  VARIANT_SEQUENCE[(order - 1) % VARIANT_SEQUENCE.length];
---

<section id="operations" class="ops-section relative">
  <div class="ops-viewport">
    <div id="ops-track" class="ops-track">

      <!-- intro panel: the archive header -->
      <div class="ops-panel ops-intro-panel">
        <div>
          <div
            class="font-mono uppercase"
            style="font-size: 11px; letter-spacing: 0.2em; color: var(--color-fg-low); margin-bottom: 16px;"
          >
            // SECTION 03
          </div>
          <div
            class="font-mono uppercase"
            style="font-size: 13px; letter-spacing: 0.15em; color: var(--color-fg-mid); line-height: 2.4; margin-top: 4px;"
          >
            <div>01. ANTIBODY</div>
            <div>02. ASCLEPIUS</div>
            <div>03. GATEKEEPER</div>
            <div>04. NORTHWALL</div>
            <div>05. SENTINEL</div>
            <div>06. VESSEL</div>
          </div>
          <p
            class="font-mono uppercase"
            style="font-size: 11px; letter-spacing: 0.15em; color: var(--color-fg-mid); line-height: 2; margin-top: 24px; max-width: 420px;"
          >
            &gt; SCROLL TO ENTER THE ARCHIVE.
          </p>
        </div>
      </div>

      <!-- case panels -->
      {sorted.map((op) => (
        <div class="ops-panel ops-case-panel" data-variant={getVariant(op.data.order)}>
          <CaseCard
            client:visible
            op={op.data}
            slug={op.slug}
            variant={getVariant(op.data.order)}
          />
        </div>
      ))}

    </div>
  </div>
</section>

<style>
  .ops-section {
    height: 100vh;
    overflow: hidden;
  }

  .ops-viewport {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .ops-track {
    display: flex;
    height: 100%;
    will-change: transform;
  }

  .ops-panel {
    flex-shrink: 0;
    width: 100vw;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 80px;
  }

  .ops-intro-panel {
    justify-content: flex-start;
    padding-left: 80px;
  }

  @media (max-width: 768px) {
    .ops-section {
      height: auto;
      overflow: visible;
    }

    .ops-viewport {
      overflow: visible;
    }

    .ops-track {
      flex-direction: column;
      height: auto;
    }

    .ops-panel {
      width: 100%;
      height: auto;
      min-height: 100vh;
      padding: 80px 24px;
      align-items: flex-start;
    }

    .ops-intro-panel {
      padding-left: 24px;
    }
  }
</style>

<script>
  import { initOperationsScroll } from '../scripts/operations-scroll';

  // Astro <script> blocks already defer until DOM is parsed — call immediately
  // so the pin spacer is inserted before Dossier/Arsenal calculate positions.
  initOperationsScroll();
</script>
