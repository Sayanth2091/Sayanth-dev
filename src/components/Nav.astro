---
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];
---
<nav class="nav" data-reveal>
  <a class="brand" href="/">SKYWALKR_2091</a>
  <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">☰</button>
  <div class="links">
    {links.map(l => <a href={l.href}>{l.label}</a>)}
  </div>
</nav>

<style>
  .nav { position: fixed; inset: 0 auto auto 0; right: 0; height: 64px; display:flex; align-items:center; justify-content:space-between; padding:0 20px; z-index:60; border-bottom: 1px solid var(--grid); }
  .brand { letter-spacing: 2px; font-weight: 800; color: var(--neon-cyan); text-decoration: none; transition: text-shadow .3s ease; }
  .brand:hover { text-shadow: 0 0 12px color-mix(in oklab, var(--neon-cyan) 70%, transparent); }
  .links { display:flex; gap:16px; }
  .links a { color: var(--text-dim); text-decoration: none; font-weight:600; position: relative; transition: color .3s ease, text-shadow .3s ease; }
  .links a::after { content:""; position:absolute; left: 50%; right: 50%; bottom:-6px; height:2px; background: linear-gradient(90deg, var(--neon-cyan), var(--neon-purple)); transform: scaleX(0); transition: left .35s cubic-bezier(.22,.61,.36,1), right .35s cubic-bezier(.22,.61,.36,1); box-shadow: 0 0 12px color-mix(in oklab, var(--neon-cyan) 50%, transparent); }
  .links a:hover { color: var(--neon-cyan); text-shadow: 0 0 12px color-mix(in oklab, var(--neon-cyan) 70%, transparent); }
  .links a:hover::after { left: 0; right: 0; }
  
  .menu-toggle { display:none !important; align-items:center; justify-content:center; height:36px; width:42px; border:1px solid var(--grid); border-radius:8px; background: color-mix(in oklab, var(--bg) 80%, transparent); color: var(--text); box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--neon-cyan) 25%, transparent); transition: transform .3s ease, box-shadow .3s ease, border-color .3s ease; }
  .menu-toggle:hover { transform: translateY(-2px); border-color: var(--neon-cyan); box-shadow: 0 0 14px color-mix(in oklab, var(--neon-cyan) 35%, transparent) }

  @media (max-width: 760px){
    /* Hide the top nav entirely on mobile; use bottom dock */
    .nav { display: none }
  }
</style>
