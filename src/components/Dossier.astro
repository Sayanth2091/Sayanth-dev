---
// Dossier.astro — Section 02: THE FIRST CUT
// The human is revealed. Shard transitions from State 0 → State 1 on enter.
---

<section
  id="dossier"
  class="dossier-section relative w-full"
>
  <!-- chapter label bar -->
  <div class="dossier-topbar">
    <span class="mono-dim">CH.01 — THE FIRST CUT</span>
    <span class="mono-dim">SUBJECT FILE</span>
  </div>

  <!-- two-column grid -->
  <div class="dossier-grid">

    <!-- LEFT: portrait -->
    <div class="portrait-col">
      <span class="portrait-caption">[ SUBJECT_PHOTO_2024.11 ]</span>

      <div id="dossier-portrait" class="portrait-frame">
        <img
          src="/images/portrait.jpg"
          alt="Subject — Sayanth Sreekanth"
          onerror="this.style.display='none'"
          class="portrait-img"
        />
      </div>

      <span class="portrait-caption" style="margin-top: 12px;">
        █████████ // DECLASSIFIED
      </span>
    </div>

    <!-- RIGHT: text blocks A–G -->
    <div class="text-col">

      <!-- Block A: mono header -->
      <div class="dossier-block db-mono db-a">
        <p class="readout-line">&gt; SUBJECT FILE OPENED</p>
        <p class="readout-line">&gt; CLEARANCE: GRANTED</p>
        <p class="readout-line">&gt; READ TIME: ~90 SECONDS</p>
      </div>

      <!-- Block B: serif -->
      <div class="dossier-block db-serif db-b">
        <p class="serif-truth">He grew up next to a river in Kerala.</p>
      </div>

      <!-- Block C: mono readout -->
      <div class="dossier-block db-mono db-c">
        <div class="readout-table">
          <div class="readout-row">
            <span class="readout-label">LOCATION</span>
            <span class="readout-leader" aria-hidden="true"></span>
            <span class="readout-value">KL/IN</span>
          </div>
          <div class="readout-row">
            <span class="readout-label">YEARS_ACTIVE</span>
            <span class="readout-leader" aria-hidden="true"></span>
            <span class="readout-value">02</span>
          </div>
          <div class="readout-row">
            <span class="readout-label">SPECIALTY</span>
            <span class="readout-leader" aria-hidden="true"></span>
            <span class="readout-value">DETECTION_ENGINEERING</span>
          </div>
          <div class="readout-row">
            <span class="readout-label">EDUCATION</span>
            <span class="readout-leader" aria-hidden="true"></span>
            <span class="readout-value">M.TECH / VIT BHOPAL</span>
          </div>
        </div>
      </div>

      <!-- Block D: serif -->
      <div class="dossier-block db-serif db-d">
        <p class="serif-truth">He noticed patterns most people miss.</p>
      </div>

      <!-- Block E: mono readout -->
      <div class="dossier-block db-mono db-e">
        <div class="readout-table">
          <div class="readout-row">
            <span class="readout-label">STATUS</span>
            <span class="readout-leader" aria-hidden="true"></span>
            <span class="readout-value">ACTIVE</span>
          </div>
          <div class="readout-row">
            <span class="readout-label">DEPLOYMENT</span>
            <span class="readout-leader" aria-hidden="true"></span>
            <span class="readout-value">REMOTE</span>
          </div>
          <div class="readout-row">
            <span class="readout-label">TIMEZONE</span>
            <span class="readout-leader" aria-hidden="true"></span>
            <span class="readout-value">UTC+5:30</span>
          </div>
          <div class="readout-row">
            <span class="readout-label">LANGUAGES</span>
            <span class="readout-leader" aria-hidden="true"></span>
            <span class="readout-value">EN, ML</span>
          </div>
        </div>
      </div>

      <!-- Block F: serif -->
      <div class="dossier-block db-serif db-f">
        <p class="serif-truth">He builds things that watch other things.</p>
      </div>

      <!-- Block G: mono close -->
      <div class="dossier-block db-mono db-g">
        <p class="readout-line">&gt; END OF FILE PREVIEW.</p>
        <p class="readout-line">&gt; DEEPER ACCESS REQUIRES TRANSMISSION.</p>
      </div>

    </div>
  </div>

  <!-- scrubber timeline -->
  <div class="scrubber-section">
    <div class="scrubber-wrap">
      <div class="scrubber-line" aria-hidden="true"></div>

      <div class="scrubber-nodes">

        <div class="scrubber-node-group">
          <span class="scrubber-label scrubber-label-above">VIT BHOPAL</span>
          <div class="scrubber-dot-wrap">
            <div class="scrubber-dot"></div>
            <div class="scrubber-tooltip" role="tooltip">
              Integrated M.Tech, Cyber Security specialization. Built a VM-IPS and a steganography app.
            </div>
          </div>
          <span class="scrubber-label scrubber-label-below">2019 — 2024</span>
        </div>

        <div class="scrubber-node-group">
          <span class="scrubber-label scrubber-label-above">VERZEO</span>
          <div class="scrubber-dot-wrap">
            <div class="scrubber-dot"></div>
            <div class="scrubber-tooltip" role="tooltip">
              Two-month internship in Bangalore. First exposure to enterprise security tooling.
            </div>
          </div>
          <span class="scrubber-label scrubber-label-below">JAN — MAR 2022</span>
        </div>

        <div class="scrubber-node-group">
          <span class="scrubber-label scrubber-label-above">DIGITAL INSIGHTS</span>
          <div class="scrubber-dot-wrap">
            <div class="scrubber-dot"></div>
            <div class="scrubber-tooltip" role="tooltip">
              Two years SOC monitoring for a Dubai MSSP. Remote from Kerala. Watched ten thousand alerts.
            </div>
          </div>
          <span class="scrubber-label scrubber-label-below">MAR 2024 — DEC 2025</span>
        </div>

        <div class="scrubber-node-group">
          <span class="scrubber-label scrubber-label-above">NOW</span>
          <div class="scrubber-dot-wrap">
            <div class="scrubber-dot"></div>
            <div class="scrubber-tooltip" role="tooltip">
              Investigating LLM security, building autonomous triage systems, looking for the next signal.
            </div>
          </div>
          <span class="scrubber-label scrubber-label-below">ACTIVE</span>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  /* ── section shell ── */
  .dossier-section {
    min-height: 100vh;
    padding: 96px 64px;
    background-color: var(--color-void);
  }

  .dossier-topbar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: 48px 64px 0;
  }

  .mono-dim {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: var(--tracking-mono-default);
    color: var(--color-fg-low);
    text-transform: uppercase;
  }

  /* ── two-column grid ── */
  .dossier-grid {
    display: grid;
    grid-template-columns: 40% 1fr;
    gap: 64px;
    margin-top: 96px;
  }

  @media (max-width: 768px) {
    .dossier-section {
      padding: 96px 24px 64px;
    }

    .dossier-topbar {
      padding: 48px 24px 0;
    }

    .dossier-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  /* ── portrait ── */
  .portrait-col {
    display: flex;
    flex-direction: column;
  }

  .portrait-caption {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: var(--tracking-mono-wide);
    color: var(--color-fg-low);
    display: block;
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .portrait-frame {
    aspect-ratio: 4 / 5;
    background-color: #1a1a22;
    border-bottom: 0.5px solid rgba(125, 249, 255, 0.2);
    position: relative;
    overflow: hidden;
  }

  /* scanlines overlay */
  .portrait-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.3) 2px,
      rgba(0, 0, 0, 0.3) 3px
    );
    opacity: 0.06;
    z-index: 1;
  }

  .portrait-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── text column ── */
  .text-col {
    display: flex;
    flex-direction: column;
  }

  /* ── blocks: base state (invisible — GSAP animates in) ── */
  .dossier-block {
    opacity: 0;
    transform: translateY(20px);
  }

  /* ── mono readout lines ── */
  .db-a,
  .db-g {
    margin-bottom: 48px;
  }

  .db-c,
  .db-e {
    margin-top: 32px;
    margin-bottom: 48px;
  }

  .readout-line {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: var(--tracking-mono-default);
    color: var(--color-fg-mid);
    line-height: 2;
    text-transform: uppercase;
  }

  /* ── readout table with dot leader ── */
  .readout-table {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .readout-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: var(--tracking-mono-default);
    line-height: 2.2;
    text-transform: uppercase;
  }

  .readout-label {
    color: var(--color-fg-mid);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .readout-leader {
    flex: 1;
    height: 1px;
    border-bottom: 1px dotted rgba(255, 255, 255, 0.18);
    position: relative;
    top: -3px;
    min-width: 16px;
  }

  .readout-value {
    color: var(--color-fg-high);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── serif truth blocks ── */
  .db-b,
  .db-d,
  .db-f {
    margin-bottom: 32px;
  }

  .serif-truth {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(28px, 3.2vw, 44px);
    line-height: 1.2;
    color: var(--color-fg-high);
  }

  /* ── scrubber timeline ── */
  .scrubber-section {
    margin-top: 96px;
  }

  .scrubber-wrap {
    position: relative;
    width: 100%;
  }

  .scrubber-line {
    position: absolute;
    left: 4px;
    right: 4px;
    top: calc(50% - 1px); /* vertically centered in the node strip */
    height: 0.5px;
    background-color: var(--color-fg-low);
    z-index: 0;
  }

  .scrubber-nodes {
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .scrubber-node-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    position: relative;
  }

  .scrubber-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: var(--tracking-mono-wide);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .scrubber-label-above {
    color: var(--color-fg-low);
  }

  .scrubber-label-below {
    color: var(--color-fg-mid);
  }

  .scrubber-dot-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .scrubber-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-accent);
    transition: width 200ms var(--ease-cinematic), height 200ms var(--ease-cinematic);
    flex-shrink: 0;
  }

  .scrubber-dot-wrap:hover .scrubber-dot {
    width: 12px;
    height: 12px;
  }

  /* tooltip */
  .scrubber-tooltip {
    position: absolute;
    bottom: calc(100% + 14px);
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    background-color: #1a1a22;
    border: 0.5px solid var(--color-accent);
    padding: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-fg-mid);
    line-height: 1.6;
    letter-spacing: var(--tracking-mono-tight);
    pointer-events: none;
    opacity: 0;
    transition: opacity 200ms var(--ease-cinematic);
    z-index: 20;
    white-space: normal;
  }

  .scrubber-dot-wrap:hover .scrubber-tooltip {
    opacity: 1;
  }

  /* ── mobile: vertical scrubber on left ── */
  @media (max-width: 768px) {
    .scrubber-section {
      margin-top: 64px;
    }

    .scrubber-wrap {
      display: flex;
    }

    .scrubber-line {
      left: calc(50% - 1px);
      right: auto;
      top: 4px;
      bottom: 4px;
      width: 0.5px;
      height: auto;
    }

    .scrubber-nodes {
      flex-direction: column;
      align-items: flex-start;
      gap: 32px;
      padding-left: 0;
      width: 100%;
    }

    .scrubber-node-group {
      flex-direction: row;
      align-items: center;
      gap: 16px;
      width: 100%;
    }

    .scrubber-label-above {
      order: 2;
      min-width: 120px;
    }

    .scrubber-label-below {
      order: 3;
      margin-left: auto;
    }

    .scrubber-dot-wrap {
      order: 1;
    }

    .scrubber-tooltip {
      top: calc(100% + 8px);
      bottom: auto;
      left: 0;
      transform: none;
    }
  }
</style>

<script>
  import '../scripts/scroll';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // entry animation — blocks A–G fade up with 80ms stagger
  // serif blocks (b, d, f) get 800ms; mono blocks (a, c, e, g) get 400ms
  const blockOrder = [
    { sel: '.db-a', serif: false },
    { sel: '.db-b', serif: true  },
    { sel: '.db-c', serif: false },
    { sel: '.db-d', serif: true  },
    { sel: '.db-e', serif: false },
    { sel: '.db-f', serif: true  },
    { sel: '.db-g', serif: false },
  ];

  const STAGGER = 0.08;

  ScrollTrigger.create({
    trigger: '#dossier',
    start: 'top 70%',
    once: true,
    onEnter: () => {
      const tl = gsap.timeline();

      blockOrder.forEach(({ sel, serif }, i) => {
        tl.to(
          sel,
          {
            opacity: 1,
            y: 0,
            duration: serif ? 0.8 : 0.4,
            ease: 'power2.out',
          },
          i * STAGGER
        );
      });
    },
  });
</script>
