---
// Dossier.astro — Section 02: THE FIRST CUT
// Editorial spread. Portrait left, vertical column rule, three chapters with
// hanging serif numerals and hairline-ruled marginalia. Shard transitions
// from State 0 → State 1 on enter.
---

<section
  id="dossier"
  class="dossier-section relative w-full"
>
  <!-- chapter label bar -->
  <div class="dossier-topbar">
    <span class="mono-dim">CH.01 — THE FIRST CUT</span>
    <span class="mono-dim">SUBJECT FILE</span>
  </div>

  <!-- editorial spread: portrait | rule | text column -->
  <div class="dossier-grid">

    <!-- LEFT: portrait -->
    <div class="portrait-col">
      <span class="portrait-caption">[ SUBJECT_PHOTO_2024.11 ]</span>

      <div id="dossier-portrait" class="portrait-frame">
        <img
          src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/images/profile.png`}
          alt="Subject — Sayanth Sreekanth"
          onerror="this.style.display='none'"
          class="portrait-img"
        />
      </div>

      <span class="portrait-caption" style="margin-top: 12px;">
        █████████ // DECLASSIFIED
      </span>
    </div>

    <!-- vertical column rule -->
    <div class="dossier-rule" aria-hidden="true"></div>

    <!-- RIGHT: editorial column -->
    <div class="text-col">

      <!-- open: file header -->
      <div class="dossier-block file-header">
        <p class="header-line">&gt; SUBJECT FILE OPENED</p>
        <p class="header-line">&gt; CLEARANCE: GRANTED</p>
        <p class="header-line">&gt; READ TIME: ~90 SECONDS</p>
      </div>

      <!-- chapter I: origin -->
      <article class="dossier-chapter dossier-block">
        <span class="chapter-numeral" aria-hidden="true">I</span>
        <p class="chapter-truth">He grew up next to a river in Kerala.</p>
        <div class="chapter-marginalia">
          <div class="readout-row">
            <span class="readout-label">LOCATION</span>
            <span class="readout-leader" aria-hidden="true"></span>
            <span class="readout-value">KL/IN</span>
          </div>
          <div class="readout-row">
            <span class="readout-label">EDUCATION</span>
            <span class="readout-leader" aria-hidden="true"></span>
            <span class="readout-value">M.TECH / VIT BHOPAL</span>
          </div>
          <div class="readout-row">
            <span class="readout-label">SPECIALTY</span>
            <span class="readout-leader" aria-hidden="true"></span>
            <span class="readout-value">DETECTION_ENGINEERING</span>
          </div>
          <div class="readout-row">
            <span class="readout-label">YEARS_ACTIVE</span>
            <span class="readout-leader" aria-hidden="true"></span>
            <span class="readout-value">02</span>
          </div>
        </div>
      </article>

      <!-- chapter II: cadence -->
      <article class="dossier-chapter dossier-block">
        <span class="chapter-numeral" aria-hidden="true">II</span>
        <p class="chapter-truth">He noticed patterns most people miss.</p>
        <div class="chapter-marginalia">
          <div class="readout-row">
            <span class="readout-label">STATUS</span>
            <span class="readout-leader" aria-hidden="true"></span>
            <span class="readout-value">ACTIVE</span>
          </div>
          <div class="readout-row">
            <span class="readout-label">DEPLOYMENT</span>
            <span class="readout-leader" aria-hidden="true"></span>
            <span class="readout-value">REMOTE</span>
          </div>
          <div class="readout-row">
            <span class="readout-label">TIMEZONE</span>
            <span class="readout-leader" aria-hidden="true"></span>
            <span class="readout-value">UTC+5:30</span>
          </div>
          <div class="readout-row">
            <span class="readout-label">LANGUAGES</span>
            <span class="readout-leader" aria-hidden="true"></span>
            <span class="readout-value">EN, ML</span>
          </div>
        </div>
      </article>

      <!-- chapter III: declaration -->
      <article class="dossier-chapter dossier-chapter--declaration dossier-block">
        <span class="chapter-numeral" aria-hidden="true">III</span>
        <p class="chapter-truth chapter-truth--italic">He builds things that watch other things.</p>
      </article>

      <!-- close: file footer -->
      <div class="dossier-block file-footer">
        <p class="header-line">&gt; END OF FILE PREVIEW.</p>
        <p class="header-line">&gt; DEEPER ACCESS REQUIRES TRANSMISSION.</p>
      </div>

    </div>
  </div>

  <!-- scrubber timeline -->
  <div class="scrubber-section">
    <div class="scrubber-wrap">
      <div class="scrubber-line" aria-hidden="true"></div>

      <div class="scrubber-nodes">

        <div class="scrubber-node-group">
          <span class="scrubber-label scrubber-label-above">VIT BHOPAL</span>
          <div class="scrubber-dot-wrap">
            <div class="scrubber-dot"></div>
            <div class="scrubber-tooltip" role="tooltip">
              Integrated M.Tech, Cyber Security specialization. Built a VM-IPS and a steganography app.
            </div>
          </div>
          <span class="scrubber-label scrubber-label-below">2019 → 2024</span>
        </div>

        <div class="scrubber-node-group">
          <span class="scrubber-label scrubber-label-above">VERZEO</span>
          <div class="scrubber-dot-wrap">
            <div class="scrubber-dot"></div>
            <div class="scrubber-tooltip" role="tooltip">
              Two-month internship in Bangalore. First exposure to enterprise security tooling.
            </div>
          </div>
          <span class="scrubber-label scrubber-label-below">JAN → MAR 2022</span>
        </div>

        <div class="scrubber-node-group">
          <span class="scrubber-label scrubber-label-above">DIGITAL INSIGHTS</span>
          <div class="scrubber-dot-wrap">
            <div class="scrubber-dot"></div>
            <div class="scrubber-tooltip" role="tooltip">
              Two years SOC monitoring for a Dubai MSSP. Remote from Kerala. Watched ten thousand alerts.
            </div>
          </div>
          <span class="scrubber-label scrubber-label-below">MAR 2024 → DEC 2025</span>
        </div>

        <div class="scrubber-node-group">
          <span class="scrubber-label scrubber-label-above">NOW</span>
          <div class="scrubber-dot-wrap">
            <div class="scrubber-dot"></div>
            <div class="scrubber-tooltip" role="tooltip">
              Investigating LLM security, building autonomous triage systems, looking for the next signal.
            </div>
          </div>
          <span class="scrubber-label scrubber-label-below">ACTIVE</span>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  /* ── section shell ── */
  .dossier-section {
    min-height: 100vh;
    padding: 96px 64px;
    background-color: var(--color-void);
  }

  .dossier-topbar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: 48px 64px 0;
  }

  .mono-dim {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: var(--tracking-mono-default);
    color: var(--color-fg-low);
    text-transform: uppercase;
  }

  /* ── editorial spread: 3-column grid with hairline rule ── */
  .dossier-grid {
    display: grid;
    grid-template-columns: 36% 1px 1fr;
    gap: 56px;
    margin-top: 96px;
    align-items: start;
  }

  .dossier-rule {
    background: linear-gradient(
      to bottom,
      transparent,
      rgba(255, 255, 255, 0.09) 8%,
      rgba(255, 255, 255, 0.09) 92%,
      transparent
    );
    align-self: stretch;
    width: 1px;
  }

  @media (max-width: 768px) {
    .dossier-section {
      padding: 96px 24px 64px;
    }

    .dossier-topbar {
      padding: 48px 24px 0;
    }

    .dossier-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .dossier-rule {
      display: none;
    }
  }

  /* ── portrait ── */
  .portrait-col {
    display: flex;
    flex-direction: column;
  }

  .portrait-caption {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: var(--tracking-mono-wide);
    color: var(--color-fg-low);
    display: block;
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .portrait-frame {
    aspect-ratio: 4 / 5;
    background-color: #1a1a22;
    border-bottom: 1px solid rgba(212, 184, 106, 0.12);
    position: relative;
    overflow: hidden;
  }

  .portrait-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── editorial column ── */
  .text-col {
    display: flex;
    flex-direction: column;
  }

  /* GSAP entry state — every block lifts in on its own scroll-trigger */
  .dossier-block {
    opacity: 0;
    transform: translateY(40px);
    will-change: opacity, transform;
  }

  .portrait-col {
    opacity: 0;
    transform: translateX(-40px);
    will-change: opacity, transform;
  }

  /* ── file header / footer (open + close mono blocks) ── */
  .file-header {
    margin-bottom: 24px;
  }

  .file-footer {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .header-line {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 300;
    line-height: 2;
    color: var(--color-fg-mid);
    letter-spacing: 0.01em;
  }

  /* ── chapters: hanging numeral + truth + marginalia ── */
  .dossier-chapter {
    position: relative;
    padding: 56px 0 56px 96px;
  }

  .dossier-chapter + .dossier-chapter {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* hanging serif italic numeral — sits in the gutter to the left of the truth */
  .chapter-numeral {
    position: absolute;
    left: 0;
    top: 52px;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(56px, 5.4vw, 88px);
    line-height: 0.85;
    color: rgba(212, 184, 106, 0.45);
    user-select: none;
    letter-spacing: -0.02em;
  }

  .chapter-truth {
    font-family: var(--font-serif);
    font-style: normal;
    font-weight: 400;
    font-size: clamp(28px, 3.2vw, 44px);
    line-height: 1.15;
    color: var(--color-fg-high);
    letter-spacing: -0.01em;
  }

  .chapter-truth--italic {
    font-style: italic;
  }

  .chapter-marginalia {
    margin-top: 28px;
    padding-top: 18px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    flex-direction: column;
    gap: 2px;
    max-width: 520px;
  }

  /* declaration chapter is bare — no marginalia, slightly more breathing room */
  .dossier-chapter--declaration {
    padding-bottom: 64px;
  }

  /* ── readout rows (now used inside chapter-marginalia) ── */
  .readout-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: var(--tracking-mono-default);
    line-height: 2.1;
    text-transform: uppercase;
  }

  .readout-label {
    color: var(--color-fg-low);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .readout-leader {
    flex: 1;
    height: 1px;
    border-bottom: 1px dotted rgba(255, 255, 255, 0.18);
    position: relative;
    top: -3px;
    min-width: 16px;
  }

  .readout-value {
    color: var(--color-fg-high);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* mobile: tighter chapter padding, smaller numeral */
  @media (max-width: 768px) {
    .dossier-chapter {
      padding: 40px 0 40px 56px;
    }

    .chapter-numeral {
      top: 38px;
      font-size: 48px;
    }

    .chapter-marginalia {
      max-width: none;
    }
  }

  /* ── scrubber timeline ── */
  .scrubber-section {
    margin-top: 96px;
  }

  .scrubber-line {
    transform-origin: left center;
    transform: scaleX(0);
  }

  .scrubber-node-group {
    opacity: 0;
    transform: translateY(12px);
  }

  .scrubber-dot {
    box-shadow: 0 0 0 0 rgba(212, 184, 106, 0);
  }

  .scrubber-dot.is-active {
    box-shadow: 0 0 12px 2px rgba(212, 184, 106, 0.6);
  }

  .scrubber-wrap {
    position: relative;
    width: 100%;
  }

  .scrubber-line {
    position: absolute;
    left: 4px;
    right: 4px;
    top: calc(50% - 1px);
    height: 0.5px;
    background-color: var(--color-fg-low);
    z-index: 0;
  }

  .scrubber-nodes {
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .scrubber-node-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    position: relative;
  }

  .scrubber-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: var(--tracking-mono-wide);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .scrubber-label-above {
    color: var(--color-fg-low);
  }

  .scrubber-label-below {
    color: var(--color-fg-mid);
  }

  .scrubber-dot-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .scrubber-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-accent);
    transition: width 200ms var(--ease-cinematic), height 200ms var(--ease-cinematic);
    flex-shrink: 0;
  }

  .scrubber-dot-wrap:hover .scrubber-dot {
    width: 12px;
    height: 12px;
  }

  .scrubber-tooltip {
    position: absolute;
    bottom: calc(100% + 14px);
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    background-color: #1a1a22;
    border: 1px solid rgba(212, 184, 106, 0.4);
    padding: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-fg-mid);
    line-height: 1.6;
    letter-spacing: var(--tracking-mono-tight);
    pointer-events: none;
    opacity: 0;
    transition: opacity 200ms var(--ease-cinematic);
    z-index: 20;
    white-space: normal;
  }

  .scrubber-dot-wrap:hover .scrubber-tooltip {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .scrubber-section {
      margin-top: 64px;
    }

    .scrubber-wrap {
      display: flex;
    }

    .scrubber-line {
      left: calc(50% - 1px);
      right: auto;
      top: 4px;
      bottom: 4px;
      width: 0.5px;
      height: auto;
    }

    .scrubber-nodes {
      flex-direction: column;
      align-items: flex-start;
      gap: 32px;
      padding-left: 0;
      width: 100%;
    }

    .scrubber-node-group {
      flex-direction: row;
      align-items: center;
      gap: 16px;
      width: 100%;
    }

    .scrubber-label-above {
      order: 2;
      min-width: 120px;
    }

    .scrubber-label-below {
      order: 3;
      margin-left: auto;
    }

    .scrubber-dot-wrap {
      order: 1;
    }

    .scrubber-tooltip {
      top: calc(100% + 8px);
      bottom: auto;
      left: 0;
      transform: none;
    }
  }
</style>

<script>
  import { onLenisReady } from '../scripts/scroll';
  import { onBootComplete } from '../scripts/boot-state';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initDossierTrigger() {
    onBootComplete(() => onLenisReady(() => {
        gsap.to('.portrait-col', {
          opacity: 1,
          x: 0,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: '#dossier',
            start: 'top 85%',
            end: 'top 30%',
            scrub: 1,
          },
        });

        const blocks = gsap.utils.toArray<HTMLElement>('.dossier-block');
        blocks.forEach((block) => {
          gsap.to(block, {
            opacity: 1,
            y: 0,
            ease: 'power2.out',
            duration: 1,
            scrollTrigger: {
              trigger: block,
              start: 'top 88%',
              end: 'top 55%',
              scrub: 1,
            },
          });
        });

        gsap.to('.scrubber-line', {
          scaleX: 1,
          ease: 'none',
          scrollTrigger: {
            trigger: '.scrubber-section',
            start: 'top 85%',
            end: 'top 40%',
            scrub: 1,
          },
        });

        const nodes = gsap.utils.toArray<HTMLElement>('.scrubber-node-group');
        nodes.forEach((node, i) => {
          gsap.to(node, {
            opacity: 1,
            y: 0,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: '.scrubber-section',
              start: `top ${75 - i * 5}%`,
              end: `top ${50 - i * 5}%`,
              scrub: 1,
              onEnter: () => node.querySelector('.scrubber-dot')?.classList.add('is-active'),
              onLeaveBack: () => node.querySelector('.scrubber-dot')?.classList.remove('is-active'),
            },
          });
        });

        ScrollTrigger.refresh();
    }));
  }

  if (document.readyState === 'complete') {
    initDossierTrigger();
  } else {
    window.addEventListener('load', initDossierTrigger, { once: true });
  }
</script>
