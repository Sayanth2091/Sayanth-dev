--- 
import StarfieldCanvas from './StarfieldCanvas.astro';
---
<section class="hero">
  <StarfieldCanvas />
  <div class="cyber-overlay" aria-hidden="true"></div>
  <div class="scan-lines" aria-hidden="true"></div>
  <div class="inner stagger" data-reveal>
    <div class="avatar" aria-hidden="true">
      <img class="avatar-img" src="/images/profile%20pfp.jpg" alt="Profile photo of Sayanth Sreekanth" loading="eager" decoding="async" width="128" height="128" />
    </div>
    <h1 class="vt-title">
      <span class="hello typing-effect" data-ani="1">Hello, I'm</span>
      <span class="name holographic" data-ani="2">Sayanth Sreekanth</span>
      <span class="alias slide-in" data-ani="3">aka <strong class="glitch neon-border" data-text="Skywalkr_2091">Skywalkr_2091</strong></span>
    </h1>
    <div class="roles-container" data-ani="4">
      <p class="roles">
        <span class="chip pulse-glow" data-delay="100">Cybersecurity • SOC Analyst</span>
        <span class="chip pulse-glow" data-delay="300">AI automation with n8n</span>
        <span class="chip pulse-glow" data-delay="500">Full‑stack web apps</span>
      </p>
    </div>
    <p class="hero-sub" data-ani="4">
      I help teams secure systems and automate the boring stuff.
    </p>
    <p class="cta magnetic-container" data-ani="4">
      <a class="btn primary hover-morph" href="/contact" aria-label="Go to contact page">
        <span class="btn-text">Contact Me</span>
        <span class="btn-bg"></span>
      </a>
      <a class="btn hover-morph" href="https://www.linkedin.com/in/sayanth-sreekanth-289950188/" target="_blank" rel="noopener" aria-label="LinkedIn profile">
        <span class="btn-text">LinkedIn</span>
        <span class="btn-bg"></span>
      </a>
      <a class="btn hover-morph" href="https://github.com/Sayanth2091" target="_blank" rel="noopener" aria-label="GitHub profile">
        <span class="btn-text">GitHub</span>
        <span class="btn-bg"></span>
      </a>
      <a class="btn hover-morph" href="/Sayanth_Sreekanth_Resume.md" download aria-label="Download resume">
        <span class="btn-text">Download Resume</span>
        <span class="btn-bg"></span>
      </a>
    </p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: grid;
    place-items: center;
    overflow: clip;
    border-bottom: 1px solid var(--grid);
    background: radial-gradient(ellipse 80% 50% at 50% 40%, rgba(7, 240, 255, 0.05), transparent);
  }
  
  /* Cyber overlay effects */
  .cyber-overlay {
    position: absolute;
    inset: 0;
    background: 
      repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(7, 240, 255, 0.02) 2px, rgba(7, 240, 255, 0.02) 4px),
      repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(164, 76, 255, 0.015) 2px, rgba(164, 76, 255, 0.015) 4px);
    animation: none;
  }
  :global(body.ready) .cyber-overlay { animation: cyberGrid 20s linear infinite; }
  
  .scan-lines {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, 
      transparent 0%, 
      rgba(7, 240, 255, 0.1) 50%, 
      transparent 100%);
    height: 3px;
    animation: none;
  }
  :global(body.ready) .scan-lines { animation: scanLine 4s ease-in-out infinite; }
  
  @keyframes cyberGrid {
    0% { transform: translateY(0); }
    100% { transform: translateY(4px); }
  }
  
  @keyframes scanLine {
    0%, 100% { top: -3px; opacity: 0; }
    50% { top: 50%; opacity: 1; }
  }

  .inner {
    position: relative;
    z-index: 2;
    padding: 120px 20px 80px;
    text-align: center;
    will-change: transform, filter;
    transform: translateY(var(--hero-ty, 0px)) scale(var(--hero-scale, 1));
    transform-origin: center top;
    filter: blur(var(--hero-blur, 0px));
  }
  
  h1 { margin: 0; line-height: 1.15; }

  .avatar {
    height: 128px;
    width: 128px;
    margin: 0 auto 14px;
    border-radius: 999px;
    border: 2px solid var(--grid);
    background: color-mix(in oklab, var(--bg) 80%, transparent);
    display: grid;
    place-items: center;
    box-shadow: 0 6px 24px rgba(7, 240, 255, 0.12);
    overflow: hidden;
  }
  .avatar-img { width: 100%; height: 100%; object-fit: cover; object-position: 50% 35%; display: block; }

  /* Enhanced typing effect */
  .hello { display: block; color: var(--text-dim); letter-spacing: 1px; opacity: 0; }
  :global(body.ready) .hello { animation: typeIn 1s ease-out 0.5s forwards; }
  
  @keyframes typeIn {
    0% { opacity: 0; transform: translateX(-20px); }
    100% { opacity: 1; transform: translateX(0); }
  }
  
  /* Beautiful name - ALWAYS VISIBLE */
  .name {
    display: block !important;
    font-size: clamp(36px, 8vw, 72px) !important;
    font-weight: 900 !important;
    position: relative !important;
    color: #07f0ff !important;
    text-shadow: 0 0 30px rgba(7, 240, 255, 0.8), 0 0 60px rgba(7, 240, 255, 0.4) !important;
    visibility: visible !important;
    opacity: 1 !important;
    transform: none !important;
  }
  
  .holographic {
    /* Beautiful holographic text effect */
    color: #07f0ff !important;
    background: transparent !important;
    -webkit-background-clip: unset !important;
    background-clip: unset !important;
    -webkit-text-fill-color: #07f0ff !important;
    animation: none;
    filter: drop-shadow(0 0 25px rgba(7, 240, 255, 0.6));
    position: relative;
  }
  
  
  @keyframes colorCycle {
    0%, 100% { 
      color: #07f0ff !important; 
      text-shadow: 0 0 30px rgba(7, 240, 255, 0.8), 0 0 60px rgba(7, 240, 255, 0.4) !important; 
    }
    50% { 
      color: #a24cff !important; 
      text-shadow: 0 0 30px rgba(164, 76, 255, 0.8), 0 0 60px rgba(164, 76, 255, 0.4) !important; 
    }
  }
  
  

  /* Enhanced alias with slide-in effect */
  .alias { display: block; margin-top: 6px; letter-spacing: 1.5px; opacity: 0; }
  :global(body.ready) .alias { animation: slideInUp 1s ease-out 1.5s forwards; }
  
  .slide-in {
    color: var(--neon-cyan);
    text-shadow: 0 0 18px color-mix(in oklab, var(--neon-cyan) 60%, transparent);
  }
  
  @keyframes slideInUp {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  
  /* Subtle neon border */
  .neon-border {
    padding: 2px 8px;
    border: 1px solid transparent;
    border-radius: 4px;
    background: linear-gradient(45deg, rgba(7, 240, 255, 0.1), rgba(164, 76, 255, 0.1));
    animation: neonPulse 2s ease-in-out infinite alternate;
  }
  :global(body.ready) .holographic { animation: colorCycle 4s ease-in-out infinite; }
  
  @keyframes neonPulse {
    0% { box-shadow: 0 0 5px rgba(7, 240, 255, 0.5); }
    100% { box-shadow: 0 0 20px rgba(7, 240, 255, 0.8), 0 0 30px rgba(164, 76, 255, 0.4); }
  }
  
  /* Clean, low-jitter glitch effect */
  .glitch { position: relative; display: inline-block; }
  .glitch::before, .glitch::after {
    content: attr(data-text);
    position: absolute; left: 0; top: 0;
    pointer-events: none; will-change: transform, opacity, filter;
    mix-blend-mode: screen;
  }
  .glitch::before { color: #07f0ff; opacity: .55; filter: drop-shadow(0 0 6px rgba(7,240,255,.4)); animation: glitchShift 4s steps(24) infinite; }
  .glitch::after  { color: #a24cff; opacity: .45; filter: drop-shadow(0 0 6px rgba(162,76,255,.35)); animation: glitchShift 4s steps(24) infinite reverse; }

  @keyframes glitchShift {
    0%, 92%, 100% { transform: translate(0, 0); opacity: .4; }
    10% { transform: translate(-1px, 1px); opacity: .6; }
    11% { transform: translate(1px, -1px); }
    12% { transform: translate(-0.5px, 0.5px); }
    20% { transform: translate(0.5px, -0.5px); }
    50% { transform: translate(0.6px, 0.6px); }
    70% { transform: translate(-0.6px, -0.4px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .glitch::before, .glitch::after { animation: none; opacity: .35; }
  }

  /* Enhanced roles container */
  .roles-container { opacity: 0; }
  :global(body.ready) .roles-container { animation: fadeInUp 1s ease-out 2s forwards; }
  
  @keyframes fadeInUp {
    0% { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  
  .roles { 
    margin: 18px auto 26px; 
    display: flex; 
    flex-wrap: wrap; 
    gap: 10px; 
    justify-content: center; 
  }
  
  /* Enhanced pulse glow chips */
  .chip { 
    border: 1px solid var(--grid); 
    color: var(--text); 
    background: color-mix(in oklab, var(--bg) 80%, transparent); 
    padding: 8px 12px; 
    border-radius: 999px; 
    font-size: 14px;
    position: relative;
    overflow: hidden;
    transform: translateY(10px);
    opacity: 0;
    transition: all 0.3s ease;
  }
  
  .pulse-glow { animation: none; }
  :global(body.ready) .pulse-glow { animation: chipReveal 0.8s ease-out forwards; }
  
  .pulse-glow[data-delay="100"] { animation-delay: 2.1s; }
  .pulse-glow[data-delay="300"] { animation-delay: 2.3s; }
  .pulse-glow[data-delay="500"] { animation-delay: 2.5s; }
  
  @keyframes chipReveal {
    0% { opacity: 0; transform: translateY(10px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  
  .chip:hover {
    border-color: var(--neon-cyan);
    box-shadow: 0 0 15px rgba(7, 240, 255, 0.4);
    transform: translateY(-2px);
  }
  
  .chip::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(45deg, transparent, rgba(7, 240, 255, 0.1), transparent);
    transform: translateX(-100%);
    transition: transform 0.6s ease;
  }
  
  .chip:hover::before {
    transform: translateX(100%);
  }
  
  /* Enhanced magnetic buttons */
  .cta { opacity: 0; }
  :global(body.ready) .cta { animation: fadeIn 1s ease-out 2.7s forwards; }
  
  @keyframes fadeIn {
    0% { opacity: 0; }
    100% { opacity: 1; }
  }
  
  .btn {
    display: inline-block;
    border: 1px solid var(--grid);
    padding: 12px 16px;
    border-radius: 10px;
    color: var(--text);
    text-decoration: none;
    margin: 4px;
    position: relative;
    overflow: hidden;
    transform: translateZ(0);
    transition: all .3s ease;
    background: transparent;
  }
  
  .btn-bg {
    position: absolute;
    inset: 0;
    background: color-mix(in oklab, var(--bg) 80%, transparent);
    transition: all 0.3s ease;
    z-index: -1;
  }
  
  .btn-text {
    position: relative;
    z-index: 1;
  }
  
  .hover-morph:hover {
    transform: translateY(-3px) scale(1.05);
    border-color: var(--neon-cyan);
    box-shadow: 0 10px 30px rgba(7, 240, 255, 0.3);
  }
  
  .hover-morph:hover .btn-bg {
    background: radial-gradient(circle at center, rgba(7, 240, 255, 0.1), rgba(164, 76, 255, 0.05));
  }
  
  .primary .btn-bg {
    background: linear-gradient(135deg, 
      color-mix(in oklab, var(--neon-cyan) 22%, transparent), 
      color-mix(in oklab, var(--neon-purple) 22%, transparent));
  }
  
  .primary.hover-morph:hover {
    box-shadow: 
      0 10px 40px rgba(7, 240, 255, 0.4), 
      0 5px 20px rgba(164, 76, 255, 0.3);
  }
  
  .primary.hover-morph:hover .btn-bg {
    background: linear-gradient(135deg, 
      color-mix(in oklab, var(--neon-cyan) 35%, transparent), 
      color-mix(in oklab, var(--neon-purple) 35%, transparent));
    transform: scale(1.1);
  }
  
  /* Magnetic effect */
  .magnetic-container {
    perspective: 1000px;
  }
  
  @media (hover: hover) {
    .btn:hover {
      animation: magneticFloat 0.1s ease-out forwards;
    }
  }
  
  @keyframes magneticFloat {
    0% { transform: translateZ(0); }
    100% { transform: translateZ(10px); }
  }

  .hero-sub {
    margin: 10px 0 18px;
    color: var(--text-dim);
    font-size: 16px;
  }
</style>
