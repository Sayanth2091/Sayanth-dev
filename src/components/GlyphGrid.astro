---
// Enhanced GlyphGrid with dynamic effects for all pages
---
<div id="glyph-grid" aria-hidden="true"></div>

<style>
  #glyph-grid {
    position: fixed;
    inset: 0;
    z-index: 0; /* behind main content (z=1) */
    opacity: .2;
    pointer-events: none; /* never block interactions */
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 12px;
    line-height: 18px;
    overflow: hidden;
    background: radial-gradient(circle at 50% 50%, rgba(7, 240, 255, 0.026) 0%, transparent 70%);
  }
  
  .glyph-cell {
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  
  .glyph-cell.pulse {
    animation: glyphPulse 1.5s ease-in-out;
  }
  
  .glyph-cell.wave {
    animation: glyphWave 2s ease-in-out;
  }
  
  @keyframes glyphPulse {
    0%, 100% { transform: scale(1); opacity: 0.36; }
    50% { transform: scale(1.5); opacity: 1; text-shadow: 0 0 12px currentColor; }
  }
  
  @keyframes glyphWave {
    0%, 100% { transform: translateY(0); opacity: 0.48; }
    25% { transform: translateY(-3px); opacity: 0.96; }
    75% { transform: translateY(3px); opacity: 0.72; }
  }
  
  @keyframes matrixFall {
    0% { transform: translateY(-20px); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateY(20px); opacity: 0; }
  }
</style>

