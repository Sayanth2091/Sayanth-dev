---
// Arsenal.astro — Section 04: THE THIRD CUT
// Skills as constellation. No bars. No percentages. Shard → State 3 on enter.
import Constellation from './Constellation.tsx';
---

<section id="arsenal" class="arsenal-section relative flex flex-col items-center">

  <!-- header text block -->
  <div class="arsenal-header">
    <p class="arsenal-label arsenal-fade">&gt; SECTION 04 // THE ARSENAL</p>
    <h2 class="arsenal-headline arsenal-fade">He doesn't collect tools.</h2>
    <h2 class="arsenal-headline arsenal-fade">He learns what they cost.</h2>
  </div>

  <!-- constellation canvas -->
  <div class="constellation-mount">
    <Constellation client:visible />
  </div>

  <!-- footer instruction -->
  <p class="arsenal-caption">[ HOVER A NODE TO READ ]</p>

</section>

<style>
  .arsenal-section {
    min-height: 100vh;
    padding: 96px 0 48px;
    background-color: var(--color-void);
    justify-content: center;
  }

  .arsenal-header {
    text-align: center;
    max-width: 720px;
    padding: 0 24px;
    margin-bottom: 48px;
  }

  .arsenal-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: var(--tracking-mono-wide);
    color: var(--color-fg-low);
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  .arsenal-headline {
    font-family: var(--font-serif);
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 400;
    line-height: 1.05;
    color: var(--color-fg-high);
  }

  .constellation-mount {
    width: 100%;
    height: 70vh;
  }

  .arsenal-caption {
    margin-top: 32px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: var(--tracking-mono-wide);
    color: var(--color-fg-low);
    text-transform: uppercase;
  }

  /* entry animation base state — GSAP animates these in */
  .arsenal-fade,
  .constellation-mount,
  .arsenal-caption {
    opacity: 0;
    transform: translateY(28px);
    will-change: opacity, transform;
  }

  .arsenal-header {
    /* the header itself stays visible; its lines fade individually */
    opacity: 1;
  }
</style>

<script>
  import { onLenisReady } from '../scripts/scroll';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initArsenalTrigger() {
    setTimeout(() => {
      onLenisReady(() => {
        const lines = gsap.utils.toArray<HTMLElement>('.arsenal-fade');
        lines.forEach((line, i) => {
          gsap.to(line, {
            opacity: 1,
            y: 0,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: '#arsenal',
              start: `top ${80 - i * 6}%`,
              end: `top ${50 - i * 6}%`,
              scrub: 1,
            },
          });
        });

        gsap.to('.constellation-mount', {
          opacity: 1,
          y: 0,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: '.constellation-mount',
            start: 'top 90%',
            end: 'top 50%',
            scrub: 1,
            onEnter: () => {
              window.dispatchEvent(new CustomEvent('null-sector:constellation-visible'));
            },
          },
        });

        gsap.to('.arsenal-caption', {
          opacity: 1,
          y: 0,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: '.arsenal-caption',
            start: 'top 95%',
            end: 'top 70%',
            scrub: 1,
          },
        });

        ScrollTrigger.refresh();
      });
    }, 0);
  }

  if (document.readyState === 'complete') {
    initArsenalTrigger();
  } else {
    window.addEventListener('load', initArsenalTrigger, { once: true });
  }
</script>
