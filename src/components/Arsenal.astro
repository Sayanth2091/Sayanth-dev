---
// Arsenal.astro — Section 04: THE THIRD CUT
// Skills as constellation. No bars. No percentages. Shard → State 3 on enter.
import Constellation from './Constellation.tsx';
---

<section id="arsenal" class="arsenal-section relative flex flex-col items-center">

  <!-- header text block -->
  <div class="arsenal-header">
    <p class="arsenal-label">&gt; SECTION 04 // THE ARSENAL</p>
    <h2 class="arsenal-headline">Tools are vocabulary.</h2>
    <h2 class="arsenal-headline italic">The grammar is what matters.</h2>
  </div>

  <!-- constellation canvas -->
  <div class="constellation-mount">
    <Constellation client:visible />
  </div>

  <!-- footer instruction -->
  <p class="arsenal-caption">[ HOVER A NODE TO READ ]</p>

</section>

<style>
  .arsenal-section {
    min-height: 100vh;
    padding: 96px 0 48px;
    background-color: var(--color-void);
    justify-content: center;
  }

  .arsenal-header {
    text-align: center;
    max-width: 720px;
    padding: 0 24px;
    margin-bottom: 48px;
  }

  .arsenal-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: var(--tracking-mono-wide);
    color: var(--color-fg-low);
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  .arsenal-headline {
    font-family: var(--font-serif);
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 400;
    line-height: 1.05;
    color: var(--color-fg-high);
  }

  .constellation-mount {
    width: 100%;
    height: 70vh;
  }

  .arsenal-caption {
    margin-top: 32px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: var(--tracking-mono-wide);
    color: var(--color-fg-low);
    text-transform: uppercase;
  }
</style>
