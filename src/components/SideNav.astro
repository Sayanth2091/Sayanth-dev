---
// SideNav.astro — fixed left-edge vertical nav, six dots, one per section
// Active dot: accent cyan. IntersectionObserver wires active state as sections are added.

const sections = [
  { id: 'hero',         label: '01 // THE BLOCK'    },
  { id: 'dossier',     label: '02 // FIRST CUT'    },
  { id: 'operations',  label: '03 // OPERATIONS'   },
  { id: 'arsenal',     label: '04 // THE ARSENAL'  },
  { id: 'transmission', label: '05 // TRANSMISSION' },
  { id: 'signoff',     label: '06 // SIGNOFF'      },
];
---

<nav
  id="side-nav"
  class="fixed left-8 top-1/2 -translate-y-1/2 z-30 flex flex-col gap-8"
  aria-label="Section navigation"
>
  {sections.map((section, i) => (
    <div class="relative group flex items-center">
      <a
        href={`#${section.id}`}
        data-section={section.id}
        class="nav-dot block rounded-full transition-all duration-200"
        style={`
          width: 6px;
          height: 6px;
          background-color: ${i === 0 ? 'var(--color-accent)' : 'rgba(255,255,255,0.25)'};
          transition: background-color 200ms var(--ease-cinematic);
        `}
        aria-label={section.label}
      />

      <span
        class="nav-tooltip absolute left-5 whitespace-nowrap pointer-events-none
               opacity-0 group-hover:opacity-100
               transition-opacity duration-200"
        style="
          font-family: var(--font-mono);
          font-size: 10px;
          letter-spacing: var(--tracking-mono-default);
          color: var(--color-fg-mid);
          text-transform: uppercase;
        "
      >
        {section.label}
      </span>
    </div>
  ))}
</nav>

<script>
  // SideNav is the single source of truth for "active section." It dispatches
  // null-sector:section-active events that other modules (shard journey, etc.)
  // can subscribe to instead of duplicating IntersectionObserver logic.
  const dots = document.querySelectorAll<HTMLAnchorElement>('.nav-dot');
  let activeId: string | null = null;

  function setActive(id: string) {
    if (id === activeId) return;
    activeId = id;
    dots.forEach((dot) => {
      const isActive = dot.dataset.section === id;
      dot.style.backgroundColor = isActive
        ? 'var(--color-accent)'
        : 'rgba(255, 255, 255, 0.25)';
    });
    window.dispatchEvent(
      new CustomEvent('null-sector:section-active', { detail: { id } }),
    );
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        setActive(entry.target.id);
      });
    },
    { threshold: 0.5 }
  );

  document.querySelectorAll('section[id]').forEach((section) => {
    observer.observe(section);
  });

  // smooth-scroll on dot click
  dots.forEach((dot) => {
    dot.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.getElementById(dot.dataset.section ?? '');
      target?.scrollIntoView({ behavior: 'smooth' });
    });
  });
</script>
